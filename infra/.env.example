# Host port remap overrides for `make dev`.
#
# Default ports inside `infra/docker-compose.dev.yml`:
#   mosquitto    1883    MQTT_PORT
#   redis        6379    REDIS_PORT (override left to compose service env)
#   clickhouse   8123    CLICKHOUSE_HTTP_PORT
#   clickhouse   9000    CLICKHOUSE_NATIVE_PORT
#   mlflow       5000    MLFLOW_PORT
#   app metrics  8080    APP_METRICS_PORT
#   prometheus   9090    PROMETHEUS_PORT
#   grafana      3000    GRAFANA_PORT
#
# Copy this file to `infra/.env` (already gitignored) and uncomment / adjust
# any port that conflicts with another local service. The values below are the
# remap baseline used during development on shared workstations.

# MQTT_PORT=11883
# CLICKHOUSE_HTTP_PORT=18123
# CLICKHOUSE_NATIVE_PORT=19000
# APP_METRICS_PORT=18080
# PROMETHEUS_PORT=19090
# GRAFANA_PORT=13000
# MLFLOW_PORT=5000
