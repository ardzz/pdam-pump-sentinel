      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * sum(rate(routemq_telemetry_points_dropped_total[5m])) / clamp_min(sum(rate(routemq_telemetry_points_accepted_total[5m])) + sum(rate(routemq_telemetry_points_dropped_total[5m])), 0.001)",
          "legendFormat": "drop share",
          "refId": "A"
        }
      ],
