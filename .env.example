APP_NAME=pdam-pump-sentinel
LOG_LEVEL=INFO
TZ=Asia/Jakarta

MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=pdam-pump-sentinel
MQTT_QOS=1

ENABLE_MYSQL=true
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pump_sentinel
DB_USER=sentinel
DB_PASSWORD=change_me

ENABLE_REDIS=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_REGISTERED_MODEL=PumpAD

RETRAIN_INTERVAL_MINUTES=30
RETRAIN_WINDOW_DAYS=7
PROMOTION_F1_DELTA=0.02
DRIFT_SHARE_THRESHOLD=0.30

SKAB_DATA_DIR=./data/skab
REPLAY_RATE_HZ=1
